# ────────────────────────────── OCR Providers ─────────────────────────────────
# ─── PaddleOCR (Local) - Default/Recommended ──────────────────────────────────
# Roda localmente sem necessidade de API key. Ideal para cupons fiscais brasileiros.
PADDLE_OCR_LOCAL_ENABLED=true

# ─── Mistral OCR (Online - Optional) ──────────────────────────────────────────
# Requer API key do Mistral. Pode ser usado como alternativa online.
# MISTRAL_API_KEY=your_api_key_here

# ─── Fiscal lookup / Official XML (Optional) ─────────────────────────────────
# NF-e model 55 XML download/verification requires certificate/authorization.
FISCAL_LOOKUP_ENABLED=false
FISCAL_PROVIDER=sefaz_dfe
