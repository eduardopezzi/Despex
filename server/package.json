{
  "name": "@open-receipt-ocr/server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "prebuild": "rm -rf dist",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "nest start -e \"node -r dotenv/config\"",
    "start:dev": "nest start --watch -e \"node -r dotenv/config\"",
    "dev": "nest start --watch -e \"node -r dotenv/config\"",
    "start:debug": "nest start --debug --watch -e \"node -r dotenv/config\"",
    "start:worker": "nest start --entryFile worker -e \"node -r dotenv/config\"",
    "start:worker:debug": "nest start --debug --entryFile worker -e \"node -r dotenv/config\"",
    "start:dev:worker": "nest start --entryFile worker --watch -e \"node -r dotenv/config\"",
    "start:prod": "node -r dotenv/config dist/main",
    "start:prod:worker": "node -r dotenv/config dist/worker",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --testPathPattern=e2e",
    "seed": "ts-node -r tsconfig-paths/register -r dotenv/config seed/seed.ts",
    "unseed": "ts-node -r tsconfig-paths/register -r dotenv/config seed/unseed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-textract": "^3.1032.0",
    "@azure/identity": "^4.13.1",
    "@google/genai": "^1.50.1",
    "@infisical/sdk": "^5.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@mistralai/mistralai": "^2.1.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@open-receipt-ocr/types": "*",
    "@types/multer": "^2.1.0",
    "axios": "^1.17.0",
    "bullmq": "^5.71.1",
    "busboy": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.8.0",
    "isomorphic-fetch": "^3.0.0",
    "jsqr": "^1.4.0",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "radash": "^12.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.21",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "jest-extended": "^7.0.0",
    "node-llama-cpp": "^3.18.1",
    "onnxruntime-node": "^1.24.3",
    "ppu-paddle-ocr": "^5.1.0 ",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
