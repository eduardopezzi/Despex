# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=9999

# ─── Secret provider ─────────────────────────────────────────────────────────
# Options: 'env' (default) | 'infisical'
SECRET_PROVIDER=env

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=data/receipt.sqlite

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

######### ─── OCR Providers ───────────────────────────────────────────────────
# ─── Mistral OCR ──────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here
# ─── TabScanner ──────────────────────────────────────────────────────────────
TAB_SCANNER_API_KEY=your-tab-scanner-api-key-here

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: 'local' (default) | 'onedrive'
STORAGE_PROVIDER=local
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_BYTES=20971520

# OneDrive (Client Credentials flow)
# Required if STORAGE_PROVIDER=onedrive
ONEDRIVE_CLIENT_ID=your-onedrive-client-id
ONEDRIVE_CLIENT_SECRET=your-onedrive-client-secret
ONEDRIVE_TENANT_ID=your-onedrive-tenant-id
# Get it using the graph client endpoint: /users/<YOUR_USER>/drive
ONEDRIVE_DRIVE_ID=your-onedrive-drive-id
# Optional: folder name in OneDrive root (default: 'UploadsForOCRApp')
ONEDRIVE_FOLDER=UploadsForOCRApp

# ─── Infisical (optional — only needed when SECRET_PROVIDER=infisical) ────────
# INFISICAL_CLIENT_ID=your_machine_client_id
# INFISICAL_CLIENT_SECRET=your_machine_client_secret
# INFISICAL_PROJECT_ID=your_infisical_project_id
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_SITE_URL=https://app.infisical.com

# ─── Volumes ──────────────────────────────────────────────────────────────────
DATA_PATH_VOLUME=./data
UPLOADS_PATH_VOLUME=./uploads
